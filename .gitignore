.env
# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

*.log

# Test / coverage artifacts
.coverage
.coverage.*
htmlcov/
