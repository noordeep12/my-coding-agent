.env
# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

*.log

# Test / coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Sphinx docs build output
docs/_build/

.my_coding_agent/handoffs/
# Ignore all of .my_coding_agent/ (ephemeral session data) EXCEPT the bundled
# example skills, which ship with the repo so they are auto-discovered. Negation
# needs the parent dir kept walkable (`/*`, not `/`) before re-including skills.
.my_coding_agent/*
!.my_coding_agent/skills/
!.my_coding_agent/skills/**
!.my_coding_agent/evals/
.my_coding_agent/evals/*
!.my_coding_agent/evals/rubrics/
!.my_coding_agent/evals/rubrics/**
# Bare name (no trailing slash) so a stray FILE or SYMLINK named .claude is
# ignored too, not just the directory — a committed self-symlink clobbers the
# local dir on checkout (see 0ffaa4f).
.claude
.codex

.hooks/.conformity_state.json

gap.md
RESEARCH.md
PLAN.md
PLAN-CHECKLIST.md
PROBLEM.md
PROBLEM.*.md

# Bare name for the same symlink reason as .claude above (see 27af23c).
openspec

CLAUDE.md
CLAUDE-*.md
AGENTS.md
AGENTS-*.md